# =============================================================================
# locateanything-d2city-zero-shot-eval — .gitignore
# =============================================================================

# --- Python / virtual environments ---
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# --- Secrets (never commit tokens) ---
.env
.env.local
.env.*.local

# --- Model weights (~8 GB; download via Hugging Face CLI) ---
models/

# --- Evaluation outputs (regenerated by scripts) ---
results/

# --- NVIDIA Eagle clone (LocateAnything upstream code) ---
# Clone manually: git clone https://github.com/NVlabs/Eagle.git eagle
eagle/

# --- D2-City dataset (large; never commit) ---
# Standalone layout: place zips under ./data/d2_city/ (see data/README.md)
data/

# Monorepo layout: when nested inside driver-assistance-system-using-RT-DETR
# (paths.data_root_mode: monorepo in config/d2city_eval.yaml)
../../data/d2_city/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# --- Logs / temp ---
*.log
.cache/
modal/.modal/
